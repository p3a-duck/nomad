---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
	.sort(
		(a, b) =>
			(b.data.updatedDate ?? b.data.pubDate).valueOf() -
			(a.data.updatedDate ?? a.data.pubDate).valueOf(),
	)
	.slice(0, 3);
const basePath = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const siteRoot = new URL(basePath, Astro.url);
const blogHref = new URL('blog/', siteRoot).toString();
const introHref = new URL('blog/astro-start/', siteRoot).toString();
const writeHref = new URL('write/', siteRoot).toString();
---

<Layout
	title="HOME | P3A-DUCK"
>
	<section class="page-section hero">
		<div class="hero-copy">
			<span class="eyebrow">조선왕조실록은 아니고, 그냥 내 실록📔</span>
			<h1></h1>
			<p>
			</p>

			<div class="hero-actions">
				<a class="primary" href={blogHref}>사초 살펴보기</a>
				<a class="secondary" href={introHref}>실록의 서문</a>
				<a class="secondary write-link" href={writeHref}>Write</a>
			</div>
		</div>

		<div class="card feature-panel">
			<p class="feature-label">Writing Focus</p>
			<ul>
				<li>Markdown 기반 작성 흐름</li>
				<li>가벼운 정적 배포 구조</li>
				<li>SEO 기본 메타데이터 공통 관리</li>
			</ul>
		</div>
	</section>

	<section class="page-section latest-posts">
		<div class="section-heading">
			<div>
				<span class="eyebrow">Latest Notes</span>
				<h2>최근 글</h2>
			</div>
			<a href={blogHref}>전체 글 보기</a>
		</div>

		<div class="post-grid">
			{posts.map((post) => (
				<PostCard post={post} />
			))}
		</div>
	</section>
</Layout>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.85fr);
		gap: 1.25rem;
		padding: 2rem 0 3rem;
		align-items: end;
	}

	h1 {
		margin: 1rem 0;
		font-size: clamp(3rem, 7vw, 6.8rem);
		line-height: 0.92;
		max-width: 10ch;
	}

	.hero-copy p {
		max-width: 44rem;
		margin: 0;
		font-size: 1.08rem;
		line-height: 1.9;
		color: var(--muted);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-top: 1.6rem;
	}

	.hero-actions a {
		text-decoration: none;
		padding: 0.95rem 1.25rem;
		border-radius: 999px;
		font-weight: 700;
	}

	.primary {
		background: var(--accent);
		color: #06101f;
		box-shadow: 0 10px 30px rgba(122, 231, 255, 0.28);
	}

	.secondary {
		border: 1px solid var(--line);
		background: rgba(12, 18, 40, 0.34);
	}

	.write-link {
		background: rgba(122, 231, 255, 0.14);
		color: var(--accent);
	}

	.feature-panel {
		padding: 1.5rem;
		background: rgba(12, 18, 40, 0.4);
	}

	.feature-label {
		margin: 0 0 0.9rem;
		font-size: 0.82rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent-deep);
		font-weight: 700;
	}

	.feature-panel ul {
		margin: 0;
		padding-left: 1.1rem;
		color: var(--muted);
		line-height: 1.9;
	}

	.latest-posts {
		padding-bottom: 2rem;
	}

	.section-heading {
		display: flex;
		justify-content: space-between;
		gap: 1rem;
		align-items: end;
		margin-bottom: 1.2rem;
	}

	h2 {
		margin: 0.8rem 0 0;
		font-size: clamp(2rem, 4vw, 3rem);
	}

	.section-heading > a {
		color: var(--muted);
		text-decoration: none;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.2rem;
	}

	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 820px) {
		.post-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
