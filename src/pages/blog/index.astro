---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
	(a, b) =>
		(b.data.updatedDate ?? b.data.pubDate).valueOf() -
		(a.data.updatedDate ?? a.data.pubDate).valueOf(),
);
---

<Layout
	title="Blog"
	description="개발 메모, 구현 기록, 실험 결과를 모아두는 글 목록입니다."
>
	<section class="page-section listing-intro">
		<span class="eyebrow">Archive</span>
		<h1>개발 과정이 남는 글 목록</h1>
		<p>
			짧은 메모부터 구현 기록까지, 시간이 지나도 다시 참고할 수 있는 형태로 정리합니다.
		</p>
	</section>

	<section class="page-section post-grid">
		{posts.map((post) => (
			<PostCard post={post} />
		))}
	</section>
</Layout>

<style>
	.listing-intro {
		padding: 2rem 0 1.6rem;
	}

	h1 {
		margin: 1rem 0 0.8rem;
		font-size: clamp(2.4rem, 5vw, 4.6rem);
		line-height: 0.95;
		max-width: 12ch;
	}

	p {
		max-width: 42rem;
		color: var(--muted);
		line-height: 1.8;
		font-size: 1.05rem;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.2rem;
	}

	@media (max-width: 820px) {
		.post-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
